# Server
PORT=3000
NODE_ENV=development
BASE_URL=http://localhost:3000
# Produktion: BASE_URL=https://fribane.io

# MongoDB
MONGODB_URI=mongodb://localhost:27017/fribane

# JWT
JWT_SECRET=skift-dette-til-noget-sikkert-i-produktion
JWT_EXPIRES_IN=7d

# Google OAuth (opret på console.cloud.google.com)
GOOGLE_CLIENT_ID=din-google-client-id
GOOGLE_CLIENT_SECRET=din-google-client-secret

# Web Push VAPID keys (generer med: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=din-vapid-public-key
VAPID_PRIVATE_KEY=din-vapid-private-key
VAPID_EMAIL=mailto:din@email.dk

# Vejdirektoratet API (hent på nap.vd.dk)
VD_API_KEY=din-vejdirektoratet-api-noegle

# Signup slots (til landing page countdown)
MAX_FREE_SLOTS=1000
